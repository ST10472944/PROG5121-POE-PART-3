<Window x:Class="CyberAwarenessChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - POE" Height="750" Width="950"
        Background="Black" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art -->
        <Label x:Name="lblAsciiArt" Grid.Row="0" 
               FontFamily="Consolas" FontSize="8" Foreground="Cyan"
               Content="Loading ASCII art..." HorizontalContentAlignment="Center"
               Background="Black" Height="140"/>

        <!-- TabControl – now has a name -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Black" Foreground="White">
            <TabItem Header="Chat" Background="#222" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <RichTextBox x:Name="txtChatLog" Grid.Row="0" 
                                 Background="Black" Foreground="Lime"
                                 FontFamily="Consolas" FontSize="12"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtUserInput" Grid.Column="0"
                                 Background="Black" Foreground="White"
                                 FontFamily="Consolas" FontSize="12"
                                 Margin="0,0,5,0"/>
                        <Button x:Name="btnSend" Grid.Column="1" Content="Send" Width="80"
                                Background="DarkCyan" Foreground="White" Margin="5,0,5,0"
                                Click="btnSend_Click"/>
                        <Button x:Name="btnExit" Grid.Column="2" Content="Exit" Width="60"
                                Background="DarkRed" Foreground="White"
                                Click="btnExit_Click"/>
                    </Grid>
                    <Label Grid.Row="2" Content="Type 'help' for menu | 'exit' to quit | NLP commands: add task, start quiz, show log"
                           Foreground="DarkGray" HorizontalContentAlignment="Center" FontSize="9"/>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks" Background="#222" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <GroupBox Header="Add New Task" Foreground="White">
                        <StackPanel Margin="5">
                            <Label Content="Title:" Foreground="White"/>
                            <TextBox x:Name="txtTaskTitle" Background="Black" Foreground="White"/>
                            <Label Content="Description:" Foreground="White"/>
                            <TextBox x:Name="txtTaskDesc" Background="Black" Foreground="White"/>
                            <Label Content="Reminder Date (optional):" Foreground="White"/>
                            <DatePicker x:Name="dpReminder" Background="Black" Foreground="White"/>
                            <Button x:Name="btnAddTask" Content="Add Task" Background="DarkGreen" Foreground="White"
                                    Click="btnAddTask_Click" Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Tasks List" Foreground="White" Grid.Row="1">
                        <ListView x:Name="lvTasks" Background="Black" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="40" DisplayMemberBinding="{Binding id}"/>
                                    <GridViewColumn Header="Title" Width="150" DisplayMemberBinding="{Binding title}"/>
                                    <GridViewColumn Header="Description" Width="200" DisplayMemberBinding="{Binding description}"/>
                                    <GridViewColumn Header="Reminder" Width="120" DisplayMemberBinding="{Binding reminder_date}"/>
                                    <GridViewColumn Header="Done" Width="50" DisplayMemberBinding="{Binding is_completed}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5">
                        <Button x:Name="btnRefreshTasks" Content="Refresh" Background="Gray" Foreground="White"
                                Click="btnRefreshTasks_Click" Margin="0,0,5,0"/>
                        <Button x:Name="btnDeleteTask" Content="Delete Selected" Background="DarkRed" Foreground="White"
                                Click="btnDeleteTask_Click" Margin="0,0,5,0"/>
                        <Button x:Name="btnCompleteTask" Content="Mark Complete" Background="DarkBlue" Foreground="White"
                                Click="btnCompleteTask_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz" Background="#222" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button x:Name="btnStartQuiz" Content="Start Quiz" Background="DarkOrange" Foreground="White"
                                Click="btnStartQuiz_Click" Margin="0,0,10,0"/>
                        <Label x:Name="lblScore" Content="Score: 0/0" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                    <GroupBox Header="Question" Grid.Row="1" Foreground="White">
                        <StackPanel>
                            <Label x:Name="lblQuestion" Content="Press 'Start Quiz' to begin" Foreground="White" FontSize="14"/>
                            <StackPanel x:Name="pnlAnswers" Margin="0,10,0,0"/>
                            <Button x:Name="btnSubmitAnswer" Content="Submit Answer" Background="DarkBlue" Foreground="White"
                                    Click="btnSubmitAnswer_Click" Visibility="Collapsed"/>
                            <Label x:Name="lblFeedback" Foreground="Yellow" Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <Button x:Name="btnNextQuestion" Content="Next Question" Background="DarkGreen" Foreground="White"
                            Grid.Row="2" Click="btnNextQuestion_Click" Visibility="Collapsed"/>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log" Background="#222" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <Button x:Name="btnRefreshLog" Content="Refresh Log" Background="Gray" Foreground="White"
                                Click="btnRefreshLog_Click"/>
                        <Button x:Name="btnShowMoreLog" Content="Show More" Background="DarkGray" Foreground="White"
                                Click="btnShowMoreLog_Click" Margin="5,0,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="lstActivityLog" Grid.Row="1" Background="Black" Foreground="White"
                             FontFamily="Consolas" FontSize="11"/>
                    <Label Grid.Row="2" Content="Shows last 10 actions. Click Show More for all." Foreground="DarkGray"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>